# DATABASE_URL para la CLI de Prisma y el seed (cwd = packages/db).
# La CLI de Prisma NO lee el .env de la raíz del monorepo; este archivo versionado
# cubre el desarrollo local (credencial local no-secreta, ver README paso 0).
# En producción/CI la variable de entorno real siempre tiene prioridad.
DATABASE_URL="postgresql://socrates:socrates@localhost:5432/socrates?schema=public"
