// ─────────────────────────────────────────────────────────────────────────────
// Sócrates — esquema de datos. La ESPINA es el Expediente.
//
// POSTGRES en desarrollo Y en producción (arquitectura §7): el entorno de
//   desarrollo trae Postgres local (rol/base `socrates`; ver README) y
//   producción es Postgres en Railway — misma base, cero sorpresas de paridad.
//   Los enums del dominio se modelan como String; los valores válidos los
//   garantiza la capa de aplicación vía @socrates/shared/glosario (pasar a
//   enums nativos de Postgres es una migración hacia adelante cuando convenga).
//   El contenido del Reporte se guarda como String (JSON serializado); pasar a
//   JSONB es igualmente una migración futura, no un requisito de hoy.
//
// Doctrina de migraciones (Director): cartas ya enviadas. Se corrige hacia
// adelante; jamás se reescribe el historial. (La migración inicial se re-cortó
// de SQLite a Postgres el 2026-07-03, ANTES de cualquier base compartida o de
// producción — ninguna carta se había enviado aún.)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Identidad / tenencia ─────────────────────────────────────────────────────
model Asesor {
  id            String       @id @default(cuid())
  clerkUserId   String       @unique // viene del JWT de Clerk (D-1)
  nombre        String?
  email         String?

  // ── Perfil de onboarding (lo que el asesor captura al entrar) ──────────────
  nombreOficina String?
  zona          String?
  especialidad  String?

  // ── Estado de onboarding y suscripción (la VERDAD del acceso vive aquí) ─────
  // onboardingEtapa: perfil | pago | bienvenida | completo (glosario ETAPAS_ONBOARDING)
  onboardingEtapa   String    @default("perfil")
  // estadoSuscripcion: ninguna | demo | prueba | activa | gracia | vencida | cancelada
  // (glosario ESTADOS_SUSCRIPCION). Lo escribe SOLO el webhook firmado de Stripe
  // (nunca el navegador). "demo" es el estado del modo demostración sin llaves,
  // explícito para no confundirlo con un pago real. Doctrina del dinero.
  estadoSuscripcion String    @default("ninguna")
  stripeCustomerId  String?   @unique
  pruebaTermina     DateTime?

  expedientes   Expediente[]
  sesiones      Sesion[]
  creadoEn      DateTime     @default(now())
  actualizadoEn DateTime     @updatedAt
}

// ── Idempotencia del webhook de Stripe ───────────────────────────────────────
// Una fila por evento de Stripe ya procesado. Si Stripe reintenta el mismo
// evento, el @id choca y NO se vuelve a aplicar (jamás doble efecto con dinero).
model EventoStripe {
  id          String   @id // event.id de Stripe ("evt_...")
  tipo        String
  procesadoEn DateTime @default(now())
}

// ── Sesiones de chat con Sócrates (línea directa al gerente) ─────────────────
model Sesion {
  id            String    @id @default(cuid())
  asesor        Asesor    @relation(fields: [asesorId], references: [id])
  asesorId      String // tenencia (NFR-8): SIEMPRE del token, nunca del payload
  titulo        String    @default("Nueva conversación")
  mensajes      Mensaje[]
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  @@index([asesorId])
}

model Mensaje {
  id        String   @id @default(cuid())
  sesion    Sesion   @relation(fields: [sesionId], references: [id], onDelete: Cascade)
  sesionId  String
  rol       String // "USUARIO" | "ASISTENTE" — validado en la capa de aplicación
  contenido String
  creadoEn  DateTime @default(now())

  @@index([sesionId])
}

// ── ESPINA: el Expediente ────────────────────────────────────────────────────
model Expediente {
  id            String       @id @default(cuid())
  asesor        Asesor       @relation(fields: [asesorId], references: [id])
  asesorId      String // tenencia (NFR-8)
  empresa       String
  ciudad        String
  industria     String
  sitioWeb      String?
  rfc           String?
  sucursales    Int?
  notas         String?
  etapa         String       @default("PROSPECTO") // EtapaExpediente (glosario)
  progreso      Int          @default(0) // derivado, persistido para listar rápido
  motivoCierre  String? // si GANADO/PERDIDO
  tareas        Tarea[]
  entregables   Entregable[]
  creadoEn      DateTime     @default(now())
  actualizadoEn DateTime     @updatedAt

  @@index([asesorId, etapa])
}

// ── Empleados (catálogo de roles) ────────────────────────────────────────────
model Empleado {
  rol         String  @id // RolEmpleado (glosario)
  nombre      String // "El Investigador"
  descripcion String // lenguaje de oficina
  tareas      Tarea[]
}

// ── Tareas (unidad de trabajo delegada) ──────────────────────────────────────
model Tarea {
  id             String      @id @default(cuid())
  expediente     Expediente  @relation(fields: [expedienteId], references: [id])
  expedienteId   String
  empleado       Empleado    @relation(fields: [empleadoRol], references: [rol])
  empleadoRol    String // RolEmpleado
  descripcion    String // legible para el Asesor
  estado         String      @default("ENCARGADA") // EstadoTarea
  motivo         String? // si BLOQUEADA (progreso honesto)
  dependeDeId    String? // dependencia entre Tareas (FR-2)
  idempotencyKey String?     @unique // anti doble efecto
  entregable     Entregable?
  creadoEn       DateTime    @default(now())
  actualizadoEn  DateTime    @updatedAt

  @@index([expedienteId, estado])
}

// ── Entregables (artefactos) + versionado ────────────────────────────────────
model Entregable {
  id            String              @id @default(cuid())
  expediente    Expediente          @relation(fields: [expedienteId], references: [id])
  expedienteId  String
  tarea         Tarea?              @relation(fields: [tareaId], references: [id])
  tareaId       String?             @unique
  empleadoRol   String? // quién lo produjo (RolEmpleado), para la bandeja
  tipo          String // "reporte_inteligencia" | "guion" | ...
  estado        String              @default("BORRADOR") // Gate humano (NFR-4)
  versiones     EntregableVersion[]
  versionActual Int                 @default(1)
  creadoEn      DateTime            @default(now())
  actualizadoEn DateTime            @updatedAt

  @@index([expedienteId])
}

model EntregableVersion {
  id            String          @id @default(cuid())
  entregable    Entregable      @relation(fields: [entregableId], references: [id])
  entregableId  String
  version       Int
  contenido     String // JSON serializado (ReporteV1, GuionV1, ...) — JSONB en Postgres
  aprobado      Boolean         @default(false)
  pdfR2Key      String? // objeto en R2 si se exportó
  verificacion  String? // auditoría de Verificación de citas (C-2), JSON serializado
  recomendaciones Recomendacion[]
  creadoEn      DateTime        @default(now())

  @@unique([entregableId, version])
}

// ── Catálogo SOC (el foso) ───────────────────────────────────────────────────
model Institucion {
  id        String     @id // id estable del catalogo-soc.json ("banorte", ...)
  nombre    String     @unique // Banorte, Konfío, ...
  tipo      String // banco | fintech | ...
  cobertura String?
  notas     String?
  fuente    String?
  productos Producto[]
}

model Producto {
  id               String          @id // id estable ("banorte-credito-revolvente", ...)
  institucion      Institucion     @relation(fields: [institucionId], references: [id])
  institucionId    String
  nombre           String
  tipo             String
  paraQueSirve     String
  cuandoRecomendar String // JSON serializado (array de strings)
  condiciones      String // JSON serializado (condicionesTipicas)
  fuente           String?
  recomendaciones  Recomendacion[]

  @@unique([institucionId, nombre])
}

// ── Recomendaciones (capa de síntesis, C-1: FK real al Catálogo) ─────────────
model Recomendacion {
  id              String            @id @default(cuid())
  version         EntregableVersion @relation(fields: [versionId], references: [id])
  versionId       String
  producto        Producto          @relation(fields: [productoId], references: [id]) // C-1
  productoId      String
  hallazgo        String // qué necesidad la originó (trazable)
  argumentoCierre String
}
