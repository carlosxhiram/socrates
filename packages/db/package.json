{
  "name": "@socrates/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:reset": "prisma migrate reset --force",
    "seed": "tsx src/seed/seed.ts",
    "build": "prisma generate && rm -rf dist && tsc -p tsconfig.build.json && cp -R src/generated dist/generated",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --experimental-strip-types",
    "test:integracion": "tsx --test tests-integracion/seed.integracion.ts"
  },
  "prisma": {
    "seed": "tsx src/seed/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@socrates/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
