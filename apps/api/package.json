{
  "name": "@socrates/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json && tsc -p tsconfig.tests.json",
    "lint": "tsc -p tsconfig.typecheck.json",
    "test": "node --test --experimental-strip-types --experimental-test-module-mocks",
    "test:integracion": "tsx --test --test-concurrency=1 tests-integracion/*.integracion.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.47",
    "@aws-sdk/client-s3": "^3.726.0",
    "@aws-sdk/s3-request-presigner": "^3.726.0",
    "@clerk/backend": "^1.21.0",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "@socrates/db": "workspace:*",
    "@socrates/shared": "workspace:*",
    "ai": "^5.0.210",
    "hono": "^4.12.0",
    "stripe": "^22.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
