{
  "name": "socrates",
  "version": "0.1.0",
  "private": true,
  "description": "Sócrates — la plataforma de agentes de IA de SOC | TALENT (monorepo)",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @socrates/db prisma:generate",
    "db:migrate": "pnpm --filter @socrates/db prisma:migrate",
    "db:seed": "pnpm --filter @socrates/db seed",
    "db:reset": "pnpm --filter @socrates/db prisma:reset"
  },
  "devDependencies": {
    "turbo": "^2.5.5",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "@clerk/shared"
    ]
  }
}
