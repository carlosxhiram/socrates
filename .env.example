# ─────────────────────────────────────────────────────────────────────────────
# Sócrates — plantilla de variables de entorno
#
# Copia este archivo a `.env` (en la raíz) y pega tus llaves.
#   cp .env.example .env
#
# REGLA DE ORO (NFR-11): la app ARRANCA SIN NINGUNA de estas llaves.
#   - Sin AI_GATEWAY_API_KEY  → Modo sin claves: los empleados usan datos sembrados.
#   - Sin TAVILY_API_KEY      → búsqueda en vivo desactivada, fallback sembrado.
#   - Sin llaves de R2         → exportar PDF degrada con mensaje honesto.
#   - Sin llaves de Clerk      → modo "asesor demo" para que La Oficina cargue en local.
#   - Sin llaves de Stripe     → onboarding en MODO DEMO: el Paso 2 no cobra y deja pasar.
# Ninguna ausencia debe tronar la aplicación.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos ────────────────────────────────────────────────────────────
# DESARROLLO: Postgres local (rol/base `socrates`; el README explica cómo crearlo
# en una línea). Si la variable falta, la api usa exactamente este default.
# PRODUCCIÓN: Postgres en Railway (red privada). Pega aquí la cadena interna:
#   DATABASE_URL="postgresql://user:pass@host:5432/railway"
DATABASE_URL="postgresql://socrates:socrates@localhost:5432/socrates?schema=public"

# ── Autenticación (Clerk) ────────────────────────────────────────────────────
# web (cliente + servidor) y api. Sin estas llaves, web corre en modo "asesor demo".
# CANDADO: en producción (NODE_ENV=production) el modo demo NO se abre solo; para
# una demo desplegada sin Clerk hay que optar explícitamente con MODO_ASESOR_DEMO=1.
# MODO_ASESOR_DEMO=1
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Verificación networkless del JWT en la api (clave pública JWKS del dashboard de Clerk).
CLERK_JWT_KEY=

# ── Frontend → API ───────────────────────────────────────────────────────────
# URL pública del servicio api (Railway). En local: http://localhost:8787
NEXT_PUBLIC_API_URL="http://localhost:8787"

# ── Inteligencia (Vercel AI Gateway) ─────────────────────────────────────────
# Strings "anthropic/claude-*". Ausente ⇒ Modo sin claves.
AI_GATEWAY_API_KEY=

# ── Búsqueda en vivo (Tavily) ────────────────────────────────────────────────
# Motor de búsqueda del Investigador. Ausente ⇒ fallback sembrado.
TAVILY_API_KEY=

# ── Almacenamiento (Cloudflare R2, S3-compatible) ────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# ── Cobro / suscripción (Stripe) ─────────────────────────────────────────────
# Onboarding con prueba gratis (Checkout, suscripción mensual). Ausente ⇒ MODO
# DEMO: el Paso 2 no cobra y da acceso de demostración. Pega tus llaves de TEST
# para activar el flujo real (no toca código):
STRIPE_SECRET_KEY=
# Secreto del endpoint de webhook (del `stripe listen` o del dashboard). Sin él,
# el webhook responde 503 honesto (no puede verificar la firma) y no aplica nada.
STRIPE_WEBHOOK_SECRET=
# Price del plan mensual ($499 MXN/mes) creado en el dashboard de Stripe. El
# precio VIVE en Stripe: el texto "$499/14 días" de la UI es contenido, no cobro.
STRIPE_PRICE_ID=
# Días de prueba gratis (default 14 si se omite).
STRIPE_TRIAL_DIAS=14
# Bandera para que la UI sepa que el cobro real está activo ("1" cuando hay llaves).
NEXT_PUBLIC_STRIPE_ENABLED=

# ── CORS / API ───────────────────────────────────────────────────────────────
# Origen del frontend permitido por la api (en local, el dev server de Next).
WEB_ORIGIN="http://localhost:3000"
# Puerto del servicio api (Railway lo inyecta en prod; en local default 8787).
PORT=8787
